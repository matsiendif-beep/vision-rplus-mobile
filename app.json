{
  "expo": {
    "name": "Vision R+",
    "slug": "vision-rplus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "visionrplus",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1C3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.visionrplus.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Utilisé pour scanner les pièces justificatives",
        "NSPhotoLibraryUsageDescription": "Accès aux photos pour joindre des documents"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B1C3D"
      },
      "package": "com.visionrplus.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-sqlite",
        { "useSQLCipher": false }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
